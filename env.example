# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini        # gpt-4o | gpt-4o-mini | gpt-4.1

# ── scraper settings ─────────────────────────
SCRAPER_CONCURRENCY=5           # parallel sites at once
SCRAPER_DELAY_SECONDS=2         # delay between requests
SCRAPER_OUTPUT_DIR=./output
SCRAPER_OUTPUT_FORMAT=json      # json | csv | sqlite
SCRAPER_CACHE_ENABLED=true
SCRAPER_CACHE_TTL_MINUTES=60    # how long cached pages are valid

# ── logging ──────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/scraper.log
